    {
      "id": "motor_efficiency_loss",
      "name": "Motor Efficiency Loss",
      "layer": "electrical",
      "desc": "Motor-side efficiency loss used to reduce the fault branch amplitude.",
      "defaultValue": 0.45,
      "moduleTargets": [
        "motor_model"
      ],
      "parameter": "efficiency",
      "tags": [
        "demo",
        "motor",
        "electrical",
        "comparison"
      ],
      "createdAt": "2026-04-28",
      "origin": "demo"
    }
  ],
