  "modelId": "evtol-fault-comparison-demo",
  "modelName": "eVTOL Normal vs Fault Comparison Demo",
  "description": "A compact but richer prewired comparison demo. It sends the same command through a normal branch and a fault-injected branch, then compares both responses in one oscilloscope.",
  "source": {
    "origin": "workbench-demo",
    "notes": "Use this package to demonstrate normal response versus motor-efficiency-loss response in CH1/CH2."
  },
  "pythonModules": [],
